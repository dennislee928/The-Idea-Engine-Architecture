FROM golang:1.25.5-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY *.go ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /idea-engine .

FROM alpine:3.21

WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /idea-engine /usr/local/bin/idea-engine

EXPOSE 8080

ENV PORT=8080

ENTRYPOINT ["/usr/local/bin/idea-engine"]
